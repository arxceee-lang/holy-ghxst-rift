local currentProcess = 0
local function playAnim(name, id)
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do track:Stop() end
    local success, obj = pcall(function() return game:GetObjects("rbxassetid://" .. id)[1] end)
    if success and obj then
        local track = animator:LoadAnimation(obj); track:Play()
        currentProcess = currentProcess + 1
        local myProcess = currentProcess
        task.spawn(function()
            local ch = TextChatService.TextChannels.RBXGeneral
            local lines = {}
            if name == "Gojo 1" then lines = {"Sorry, Amanai.", "I'm not even angry over you right now.", "I bear no grudge against anyone.", "It's just that… the world feels so, so wonderful right now.", "Throughout heaven and earth, I alone am the honored one."}
            elseif name == "Gojo 2" then lines = {"Throughout heaven and earth, I alone am the honored one."}
            elseif name == "Infinite Void" then lines = {"Ryōiki Tenkai: Muryōkūsho"}
            elseif name == "Yuji" then lines = {"I still don’t know what it means to die naturally…", "until I do, and until I can kill that thing…", "I won’t lose to anything."}
            elseif name == "Jackpot" then lines = {"I JUST HIT THE JACKPOTTTTT!!!!!!!!"}
            elseif name == "Sukuna" then lines = {"A system that isn't based purely on strength is boring if you ask me.", "When I make this kid's body mine...", "you'll be the first one I kill."}
            elseif name == "Fuga" then lines = {"Open.", "■."}
            elseif name == "Toji" then lines = {"Blessings to the boy who has everything...", "and nothing at all."}
            elseif name == "Aizen" then lines = {"Admiration is the furthest thing from understanding."}
            elseif name == "Madara" then lines = {"This world is no longer worth surviving in.", "...Hmph."}
            elseif name == "Mahoraga Summoning" then lines = {"With this treasure, I summon", "Eight-Handled Sword Divergent Sila Divine General Mahoraga"}
            elseif name == "Guts" then lines = {"*Heavy breathing*", "I'm just a man struggling against the current."}
            elseif name == "Ichigo" then lines = {"If fate is a millstone...", "we are the grist."}
            elseif name == "Zoro Purgatory Aura" then lines = {"Beyond the Nine Mountains and Eight Seas...", "There is nothing I cannot cut."}
