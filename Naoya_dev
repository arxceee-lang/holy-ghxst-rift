local blur = Lighting:FindFirstChild("GhxstBlur")
if not blur then
	blur = Instance.new("BlurEffect")
	blur.Name = "GhxstBlur"
	blur.Size = 0
	blur.Parent = Lighting
end

local function blurIn()
	blur.Size = 1
	local tween = TweenService:Create(blur, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = 30})
	tween:Play()
end

local function blurOut()
	local tween = TweenService:Create(blur, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = 0})
	tween:Play()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
